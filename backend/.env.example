# Copy to backend/.env and fill in. Loom reads provider keys from the environment.

# --- LLM provider keys (set at least one; Loom picks per-call) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- Default model routing (used by services/llm.py) ---
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# --- Web search (services/search.py); leave blank to use the stub ---
SEARCH_API_KEY=
SEARCH_PROVIDER=tavily

# --- Optional persistence ---
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/loom_research
# REDIS_URL=redis://localhost:6379/0

# --- App ---
CORS_ORIGINS=http://localhost:3000
